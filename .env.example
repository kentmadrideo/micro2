# Copy this file to .env and fill in your values.
# Do NOT commit .env with secrets.

# MongoDB connection URI (replace <password> and other placeholders)
MONGODB_URI=mongodb+srv://AutoShop:<db_password>@cluster0.idhybli.mongodb.net/?appName=Cluster0

# Database and collection names
MONGODB_DB=micro
MONGODB_COLLECTION=measurements

# HTTP port for the server
HTTP_PORT=3000
